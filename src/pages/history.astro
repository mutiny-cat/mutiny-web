---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout lang="ca" title="Mutiny — La història">
  <div class="editor-window">
    <div class="window-title-bar">
      <span class="window-title">MUTINY.PAS</span>
      <div class="window-controls" aria-hidden="true">
        <span class="ctrl">↑</span>
        <span class="ctrl">↓</span>
        <span class="ctrl">×</span>
      </div>
    </div>
    <div class="window-body">
      <pre class="code"><span class="kw">unit</span> Mutiny;

<span class="kw">(*</span>
  Inspirat en la sèrie
  "Halt and Catch Fire" (AMC)

  Cameron Howe i Donna Clark
  van fundar Mutiny Enterprises
  als anys 80. Un homenatge
  als inicis de la informàtica
  personal i a les dones
  que van fer-la possible.
<span class="kw">*)</span>

<span class="kw">begin</span>
  WriteLn(<span class="str">'Keep calm and'</span>);
  WriteLn(<span class="str">'halt and catch fire.'</span>);
<span class="kw">end</span>.</pre>
    </div>
    <div class="window-status">
      <span>Line 1  Col 1</span>
      <span>Insert Indent</span>
    </div>
  </div>
</BaseLayout>

<style>
  .editor-window {
    position: absolute;
    inset-block-start: 40px;
    inset-inline-start: 50%;
    translate: -50% 0;
    background: var(--editor-bg);
    border: 2px solid;
    border-color: var(--border-light) var(--border-dark) var(--border-dark) var(--border-light);
    min-inline-size: 480px;
  }

  .window-title-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--menu-bg);
    color: #000;
    padding-block: 4px;
    padding-inline: 8px;
    font-size: var(--font-size);
    font-weight: 700;
    border-block-end: 1px solid var(--border-dark);
  }

  .window-controls { display: flex; gap: 1px; }

  .ctrl {
    display: inline-block;
    padding-inline: 4px;
    cursor: pointer;
    border: 1px solid var(--border-dark);
    background: var(--menu-bg);
    font-size: var(--font-size);
    &:hover { background: var(--menu-highlight-bg); color: var(--menu-highlight-fg); }
  }

  .window-body { padding: 8px; }

  .code {
    font-family: var(--font-mono);
    font-size: var(--font-size);
    line-height: 1.5;
    color: var(--editor-fg);
    white-space: pre;
  }

  .kw { color: #ff0; }
  .str { color: #f0f; }

  .window-status {
    display: flex;
    justify-content: space-between;
    background: var(--menu-bg);
    color: #000;
    padding-inline: 6px;
    padding-block: 2px;
    font-size: var(--font-size);
    font-weight: 700;
    border-block-start: 1px solid var(--border-dark);
  }
</style>
