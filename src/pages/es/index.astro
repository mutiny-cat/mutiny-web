---
import BaseLayout from '../../layouts/base-layout.astro';
---

<BaseLayout lang="es">
  <div class="desktop-content">
    <div class="desktop-cursor">█</div>
  </div>
</BaseLayout>

<style>
  .desktop-content {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .desktop-cursor {
    position: absolute;
    top: 80px;
    left: 60px;
    color: var(--editor-fg);
    font-size: var(--font-size);
    font-family: var(--font-mono);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
