---
import BaseLayout from '../../layouts/base-layout.astro';
---

<BaseLayout lang="ca" title="Mutiny — Projectes">
      <div class="editor-window" role="region" aria-label="Editor: PROJ.PAS">
    <div class="window-title-bar">
      <span class="window-title">PROJ.PAS</span>
      <div class="window-controls" aria-hidden="true">
        <span class="ctrl">↑</span>
        <span class="ctrl">↓</span>
        <span class="ctrl">×</span>
      </div>
    </div>
    <div class="window-body">
      <pre class="code" tabindex="0"><span class="kw">program</span> Projects;

<span class="kw">type</span>
  TProject = <span class="kw">record</span>
    name: <span class="kw">string</span>[40];
    status: (active, paused, done);
  <span class="kw">end</span>;

<span class="kw">const</span>
  projects: <span class="kw">array</span>[1..3] <span class="kw">of</span> TProject = (
    (name: <span class="str">'mutiny-web'</span>; status: active),
    (name: <span class="str">'turbo-ui'</span>;   status: active),
    (name: <span class="str">'retro-blog'</span>; status: paused),
  );

<span class="kw">var</span>
  i: <span class="kw">integer</span>;

<span class="kw">begin</span>
  <span class="kw">for</span> i := 1 <span class="kw">to</span> 3 <span class="kw">do</span>
    WriteLn(projects[i].name);
<span class="kw">end</span>.</pre>
    </div>
    <div class="window-status">
      <span>Line 22  Col 5</span>
      <span>Insert Indent</span>
    </div>
  </div>
</BaseLayout>

<style>
  .editor-window {
    position: absolute;
    inset-block-start: 40px;
    inset-inline-start: 50%;
    translate: -50% 0;
    background: var(--editor-bg);
    border: 2px solid;
    border-color: var(--border-light) var(--border-dark) var(--border-dark) var(--border-light);
    min-inline-size: 480px;
  }

  .window-title-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--menu-bg);
    color: #000;
    padding-block: 4px;
    padding-inline: 8px;
    font-size: var(--font-size);
    font-weight: 700;
    border-block-end: 1px solid var(--border-dark);
  }

  .window-controls {
    display: flex;
    gap: 1px;
  }

  .ctrl {
    display: inline-block;
    padding-inline: 4px;
    cursor: pointer;
    border: 1px solid var(--border-dark);
    background: var(--menu-bg);
    font-size: var(--font-size);

    &:hover {
      background: var(--menu-highlight-bg);
      color: var(--menu-highlight-fg);
    }
  }

  .window-body {
    padding: 8px;
  }

  .code {
    font-family: var(--font-mono);
    font-size: var(--font-size);
    line-height: 1.5;
    color: var(--editor-fg);
    white-space: pre;
  }

  .kw {
    color: #ff0;
  }

  .str {
    color: #f0f;
  }

  .window-status {
    display: flex;
    justify-content: space-between;
    background: var(--menu-bg);
    color: #000;
    padding-inline: 6px;
    padding-block: 2px;
    font-size: var(--font-size);
    font-weight: 700;
    border-block-start: 1px solid var(--border-dark);
  }
</style>
