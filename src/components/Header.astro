---
import { useTranslations } from '../i18n/utils';
import { languages, defaultLang } from '../i18n/ui';

export interface Props {
  lang?: 'ca' | 'es';
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<header role="banner">
  <div class="menu-bar" role="menubar" aria-label={lang === 'ca' ? "Navegació principal" : "Navegación principal"}>
    <div class="menu-left" role="group">
      <span class="hamburger" role="button" tabindex="0" aria-label="Menú">☰</span>
      <a href="/" class="menu-item" role="menuitem">{t('nav.inici')}</a>
      <a href="/blog" class="menu-item" role="menuitem">{t('nav.blog')}</a>
      <a href="/projects" class="menu-item" role="menuitem">{t('nav.projectes')}</a>
      <a href="/about" class="menu-item" role="menuitem">{t('nav.acerca')}</a>
    </div>

    <span class="menu-center">[Mutiny — Turbo Edition]</span>

    <nav class="lang-switcher" aria-label={lang === 'ca' ? "Canvi d'idioma" : "Cambio de idioma"}>
      {Object.entries(languages).map(([code, label]) => (
        code === lang
          ? <span class="lang-item lang-current">[{label}]</span>
          : <a href={code === defaultLang ? '/' : `/${code}/`} class="lang-item lang-link">[{label}]</a>
      ))}
    </nav>
  </div>
</header>

<style>
  header {
    flex-shrink: 0;
  }

  .menu-bar {
    display: flex;
    align-items: center;
    background: var(--menu-bg);
    color: var(--menu-fg);
    padding-block: 4px;
    padding-inline: 24px;
    font-size: var(--font-size);
    flex-shrink: 0;
    border-block-end: 1px solid var(--border-dark);
  }

  .menu-left {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .menu-center {
    flex-shrink: 0;
    color: #000;
    font-size: 0.85em;
    white-space: nowrap;

    &::first-letter {
      color: #ff0000;
    }
  }

  .menu-item {
    padding-inline: 12px;
    padding-block: 2px;
    color: #000;
    font-weight: 700;

    &::first-letter {
      color: #ff0000;
    }

    &:hover,
    &:focus-visible {
      background: var(--menu-highlight-bg);
      color: var(--menu-highlight-fg);
      outline: none;
    }
  }

  .hamburger {
    padding-inline: 8px;
    font-size: var(--font-size);
    line-height: 1;
    color: #ff0000;

    &:hover,
    &:focus-visible {
      background: var(--menu-highlight-bg);
      color: var(--menu-highlight-fg);
      outline: none;
    }
  }

  .lang-switcher {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    gap: 4px;
    font-size: 0.85em;
  }

  .lang-item {
    padding-inline: 6px;
    padding-block: 2px;
    color: #000;
    font-weight: 700;

    &::first-letter {
      color: #ff0000;
    }

    &:hover,
    &:focus-visible {
      background: var(--menu-highlight-bg);
      color: var(--menu-highlight-fg);
      outline: none;
    }
  }

  .lang-current {
    color: #000088;
  }

  :focus-visible {
    outline: 2px solid var(--menu-highlight-bg);
    outline-offset: 2px;
  }
</style>
