---
import { useTranslations } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

export interface Props {
  lang?: 'ca' | 'es';
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer role="contentinfo">
  <div class="status-bar">
    <nav aria-label={lang === 'ca' ? "Enllaços legals" : "Enlaces legales"}>
      <a href="#" class="legal-link">{t('nav.legal')}</a>
      <a href="#" class="legal-link">{t('nav.privacitat')}</a>
      <a href="#" class="legal-link">{t('nav.cookies')}</a>
      <a href="#" class="legal-link">{t('nav.accessibilitat')}</a>
      <a href="#" class="legal-link">{t('nav.credits')}</a>
    </nav>
    <span class="footer-text"><span class="cc-icon" aria-hidden="true">CC</span> Mutiny &mdash; Turbo Edition (1993 &ndash; {year})</span>
  </div>
</footer>

<style>
  footer {
    flex-shrink: 0;
  }

  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--status-bg);
    color: #000;
    padding-block: 4px;
    padding-inline: 24px;
    font-size: var(--font-size);
    font-weight: 700;
    border-block-start: 1px solid var(--border-dark);
  }

  .footer-text::first-letter {
    color: #ff0000;
  }

  .cc-icon {
    display: inline-block;
    border: 2px solid #000;
    border-radius: 50%;
    padding-inline: 4px;
    font-size: 0.8em;
    line-height: 1.2;
    font-weight: 700;
    margin-inline-end: 4px;
  }

  nav {
    flex: 1;
    display: flex;
    gap: 20px;
  }

  .legal-link {
    color: #000;

    &::first-letter {
      color: #ff0000;
    }

    &:hover,
    &:focus-visible {
      background: var(--menu-highlight-bg);
      color: var(--menu-highlight-fg);
      outline: none;
    }
  }

  :focus-visible {
    outline: 2px solid var(--menu-highlight-bg);
    outline-offset: 2px;
  }
</style>
