---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = "Turbo Pascal", description = "" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <div class="turbo-container">
      <Header />
      <main id="main-content" class="desktop" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -9999px;
    left: -9999px;
    z-index: 1000;
    background: #000;
    color: #fff;
    padding: 8px 16px;
    font-size: 16px;
    font-weight: 700;

    &:focus {
      top: 0;
      left: 0;
    }
  }

  .turbo-container {
    display: flex;
    flex-direction: column;
    block-size: 100vh;
  }

  .desktop {
    flex: 1;
    overflow: auto;
    position: relative;
    background: var(--desktop-bg);

    &:focus {
      outline: none;
    }
  }
</style>
